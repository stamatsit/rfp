{
  "name": "rfp-proposals",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "npm run dev -w @rfp-proposals/client",
    "dev:server": "npm run dev -w @rfp-proposals/server",
    "build": "npm run build -w @rfp-proposals/client && npm run build -w @rfp-proposals/server",
    "vercel-build": "npm run build -w @rfp-proposals/client",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  }
}
