{
  "name": "rfp-proposals",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "npm run dev -w @rfp-proposals/client",
    "dev:server": "npm run dev -w @rfp-proposals/server",
    "build": "npm run build -w @rfp-proposals/client && npm run build -w @rfp-proposals/server",
    "vercel-build": "npm run build -w @rfp-proposals/client && npm run build:api",
    "build:api": "esbuild api/index.ts --bundle --platform=node --target=node18 --outfile=api/index.js --format=esm --external:@supabase/supabase-js --external:drizzle-orm --external:postgres --external:express --external:express-session --external:cors --external:dotenv --external:openai --external:multer --external:mammoth --external:xlsx --external:uuid --external:zod",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "@vercel/node": "^3.0.0",
    "concurrently": "^8.2.2",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "drizzle-orm": "^0.29.5",
    "express": "^4.18.2",
    "express-session": "^1.18.2",
    "mammoth": "^1.11.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^6.16.0",
    "postgres": "^3.4.3",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  }
}
