{
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "packages/client/dist",
  "installCommand": "npm install",
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/((?!api).*)", "destination": "/" }
  ]
}
